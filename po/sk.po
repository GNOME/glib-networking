msgstr "Neprijateľný certifikát pre TLS"

#: tls/base/gtlsconnection-base.c:2179
#, c-format
msgid "Receive flags are not supported"
msgstr "Prijímanie značiek nie je podporované"

#: tls/base/gtlsconnection-base.c:2320
#, c-format
